# Multi-Dimensional GMM Examples
# This file demonstrates the usage of multi-dimensional GMMs in ProbSPARQL

@prefix uq: <http://www.example.org/uncertainQuantities#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# 2D GMM Example: Location uncertainty with x,y coordinates
<var1> uq:hasDistribution """
{
  "K": 2,
  "d": 2,
  "covariance_type": "diag",
  "weights": [0.6, 0.4],
  "means": [
    [0.0, 0.0],
    [5.0, 5.0]
  ],
  "covariances": [
    [[1.0], [1.0]],
    [[2.0], [2.0]]
  ]
}
"""^^<http://probsparql.org/datatype#GMM> .

# Another 2D GMM for comparison
<var2> uq:hasDistribution """
{
  "K": 1,
  "d": 2,
  "covariance_type": "spherical",
  "weights": [1.0],
  "means": [[2.5, 2.5]],
  "covariances": [[[1.5]]]
}
"""^^<http://probsparql.org/datatype#GMM> .

# 3D GMM Example: RGB color uncertainty
<color1> uq:hasDistribution """
{
  "K": 3,
  "d": 3,
  "covariance_type": "spherical",
  "weights": [0.5, 0.3, 0.2],
  "means": [
    [255.0, 0.0, 0.0],
    [0.0, 255.0, 0.0],
    [0.0, 0.0, 255.0]
  ],
  "covariances": [
    [[100.0]],
    [[100.0]],
    [[100.0]]
  ]
}
"""^^<http://probsparql.org/datatype#GMM> .

# 4D GMM Example: Space-time event
<event1> uq:hasDistribution """
{
  "K": 1,
  "d": 4,
  "covariance_type": "diag",
  "weights": [1.0],
  "means": [[10.0, 20.0, 30.0, 1000.0]],
  "covariances": [[[2.0], [3.0], [4.0], [100.0]]]
}
"""^^<http://probsparql.org/datatype#GMM> .
