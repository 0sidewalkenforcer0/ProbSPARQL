@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

@prefix ag:   <http://example.org/anglegrinder#> .
@prefix cfm:  <http://example.org/circularfactorymeasure#> .
@prefix uq:   <http://example.org/uncertainty#> .
@prefix ns:   <http://example.org/materialscience#> .
@prefix ex:   <http://example.org/data/circular-factory/> .

ag:hasCarbonContentCharacteristic a rdf:Property ;
    rdfs:label "has carbon content characteristic" .

ag:hasTemperatureCharacteristic a rdf:Property ;
    rdfs:label "has temperature characteristic" .

ag:hasBarkhausenRmsCharacteristic a rdf:Property ;
    rdfs:label "has Barkhausen RMS characteristic" .

ag:hasHardnessCharacteristic a rdf:Property ;
    rdfs:label "has hardness characteristic" .

ag:hasResidualStressCharacteristic a rdf:Property ;
    rdfs:label "has residual stress characteristic" .

# One product instance and one part instance.
ex:angle_grinder_001 a ag:AngleGrinder ;
    rdfs:label "Angle Grinder 001" ;
    ag:hasPart ex:bevel_gear_001 .

ex:bevel_gear_001 a ag:BevelGear ;
    rdfs:label "Bevel Gear 001 for B02-B03-A03 demonstration" ;
    ag:hasCarbonContentCharacteristic ex:carbon_content_char_001 ;
    ag:hasTemperatureCharacteristic ex:temperature_char_001 ;
    ag:hasBarkhausenRmsCharacteristic ex:barkhausen_rms_char_001 ;
    ag:hasHardnessCharacteristic ex:hardness_char_001 ;
    ag:hasResidualStressCharacteristic ex:residual_stress_char_001 .

# Five characteristics defined from the domain description.
ex:carbon_content_char_001 a cfm:MeasurableCharacteristics ;
    rdfs:label "Carbon Content" .

ex:temperature_char_001 a cfm:MeasurableCharacteristics ;
    rdfs:label "Test Temperature" .

ex:barkhausen_rms_char_001 a cfm:MeasurableCharacteristics ;
    rdfs:label "Barkhausen Noise RMS" .

ex:hardness_char_001 a cfm:MeasurableCharacteristics ;
    rdfs:label "Hardness" .

ex:residual_stress_char_001 a cfm:MeasurableCharacteristics ;
    rdfs:label "Residual Stress" .

# Deterministic measurements.
ex:measurement_cc_001 a cfm:Measurement ;
    rdfs:label "Carbon content measurement for Bevel Gear 001" ;
    cfm:measuresCharacteristic ex:carbon_content_char_001 ;
    cfm:hasValue "25"^^xsd:decimal .

ex:measurement_temp_001 a cfm:Measurement ;
    rdfs:label "Temperature measurement for Bevel Gear 001" ;
    cfm:measuresCharacteristic ex:temperature_char_001 ;
    cfm:hasValue "30"^^xsd:decimal .

# Probabilistic measurements kept as three independent random variables.
ex:measurement_rms_001 a cfm:Measurement ;
    rdfs:label "Barkhausen RMS distribution for Bevel Gear 001" ;
    cfm:measuresCharacteristic ex:barkhausen_rms_char_001 ;
    cfm:hasProbabilisticValue ex:rv_rms_001 .

ex:measurement_hardness_001 a cfm:Measurement ;
    rdfs:label "Hardness distribution for Bevel Gear 001" ;
    cfm:measuresCharacteristic ex:hardness_char_001 ;
    cfm:hasProbabilisticValue ex:rv_hardness_001 .

ex:measurement_rs_001 a cfm:Measurement ;
    rdfs:label "Residual stress distribution for Bevel Gear 001" ;
    cfm:measuresCharacteristic ex:residual_stress_char_001 ;
    cfm:hasProbabilisticValue ex:rv_rs_001 .

# Independent 1D distributions, intentionally not fused into one joint model.
ex:rv_rms_001 a cfm:RandomVariable ;
    uq:hasDistribution """{
        "n_components": 2,
        "dimensions": 1,
        "covariance_type": "full",
        "weights": [0.58, 0.42],
        "means": [
            [268.4],
            [272.1]
        ],
        "covariances": [
            [[8.2]],
            [[5.6]]
        ]
    }"""^^<http://example.org/ontology/uncertainty#gmmLiteral> .

ex:rv_hardness_001 a cfm:RandomVariable ;
    uq:hasDistribution """{
        "n_components": 2,
        "dimensions": 1,
        "covariance_type": "full",
        "weights": [0.61, 0.39],
        "means": [
            [478.0],
            [483.7]
        ],
        "covariances": [
            [[16.0]],
            [[9.0]]
        ]
    }"""^^<http://example.org/ontology/uncertainty#gmmLiteral> .

ex:rv_rs_001 a cfm:RandomVariable ;
    uq:hasDistribution """{
        "n_components": 2,
        "dimensions": 1,
        "covariance_type": "full",
        "weights": [0.54, 0.46],
        "means": [
            [21.9],
            [22.8]
        ],
        "covariances": [
            [[1.44]],
            [[0.81]]
        ]
    }"""^^<http://example.org/ontology/uncertainty#gmmLiteral> .

