# ============================================
# CT Scanner Measurements with Uncertainty
# ============================================

ex:measurement_ct_001 a om:Measure ;
    rdfs:label "CT Tooth Length Measurement (Gear #001)"@en ;
    cfm:hasInputVoxelGrid ex:voxelgrid_001 ;
    cfm:measuresCharacteristic ex:toothlength_char_001 ;
    cfm:hasProbabilisticValue ex:rv_ct_001 ;
    om:hasValue "9.15"^^xsd:double ;
    om:hasUnit om:millimetre ;
    rdfs:comment "CT measurement: 9.15mm (close to SL 9.2mm, small divergence)"@en .

ex:measurement_ct_002 a om:Measure ;
    rdfs:label "CT Tooth Length Measurement (Gear #002)"@en ;
    cfm:hasInputVoxelGrid ex:voxelgrid_002 ;
    cfm:measuresCharacteristic ex:toothlength_char_002 ;
    cfm:hasProbabilisticValue ex:rv_ct_002 ;
    om:hasValue "9.8"^^xsd:double ;
    om:hasUnit om:millimetre ;
    rdfs:comment "CT measurement: 9.8mm (good agreement with SL)"@en .

ex:measurement_ct_003 a om:Measure ;
    rdfs:label "CT Tooth Length Measurement (Gear #003)"@en ;
    cfm:hasInputVoxelGrid ex:voxelgrid_003 ;
    cfm:measuresCharacteristic ex:toothlength_char_003 ;
    cfm:hasProbabilisticValue ex:rv_ct_003 ;
    om:hasValue "10.2"^^xsd:double ;
    om:hasUnit om:millimetre ;
    rdfs:comment "CT measurement: 10.2mm (good agreement with SL)"@en .

ex:measurement_ct_004 a om:Measure ;
    rdfs:label "CT Tooth Length Measurement (Gear #004)"@en ;
    cfm:hasInputVoxelGrid ex:voxelgrid_004 ;
    cfm:measuresCharacteristic ex:toothlength_char_004 ;
    cfm:hasProbabilisticValue ex:rv_ct_004 ;
    om:hasValue "9.05"^^xsd:double ;
    om:hasUnit om:millimetre ;
    rdfs:comment "CT measurement: 9.05mm (close to SL 9.1mm, small divergence)"@en .

ex:measurement_ct_005 a om:Measure ;
    rdfs:label "CT Tooth Length Measurement (Gear #005)"@en ;
    cfm:hasInputVoxelGrid ex:voxelgrid_005 ;
    cfm:measuresCharacteristic ex:toothlength_char_005 ;
    cfm:hasProbabilisticValue ex:rv_ct_005 ;
    om:hasValue "9.25"^^xsd:double ;
    om:hasUnit om:millimetre ;
    rdfs:comment "CT measurement: 9.25mm (close to SL 9.3mm, small divergence)"@en .

ex:measurement_ct_006 a om:Measure ;
    rdfs:label "CT Tooth Length Measurement (Gear #006)"@en ;
    cfm:hasInputVoxelGrid ex:voxelgrid_006 ;
    cfm:measuresCharacteristic ex:toothlength_char_006 ;
    cfm:hasProbabilisticValue ex:rv_ct_006 ;
    om:hasValue "9.45"^^xsd:double ;
    om:hasUnit om:millimetre ;
    rdfs:comment "CT measurement: 9.45mm (close to SL 9.5mm, small divergence)"@en .

ex:measurement_ct_007 a om:Measure ;
    rdfs:label "CT Tooth Length Measurement (Gear #007)"@en ;
    cfm:hasInputVoxelGrid ex:voxelgrid_007 ;
    cfm:measuresCharacteristic ex:toothlength_char_007 ;
    cfm:hasProbabilisticValue ex:rv_ct_007 ;
    om:hasValue "10.0"^^xsd:double ;
    om:hasUnit om:millimetre ;
    rdfs:comment "CT measurement: 10.0mm ⚠️ ABNORMAL: large divergence from SL (10.8mm)"@en .

ex:measurement_ct_008 a om:Measure ;
    rdfs:label "CT Tooth Length Measurement (Gear #008)"@en ;
    cfm:hasInputVoxelGrid ex:voxelgrid_008 ;
    cfm:measuresCharacteristic ex:toothlength_char_008 ;
    cfm:hasProbabilisticValue ex:rv_ct_008 ;
    om:hasValue "10.2"^^xsd:double ;
    om:hasUnit om:millimetre ;
    rdfs:comment "CT measurement: 10.2mm ⚠️ ABNORMAL: large divergence from SL (10.8mm)"@en .

