@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix core: <http://example.org/ontology/core#> .
@prefix ag: <http://example.org/ontology/anglegrinder#> .
@prefix cfm: <http://example.org/ontology/cfm#> .
@prefix om: <http://example.org/ontology/om#> .
@prefix uq: <http://example.org/ontology/uncertainty#> .
@prefix ex: <http://example.org/data/> .

# ============================================
# Units of Measurement - Instance Data
# ============================================

om:millimetre a om:LengthUnit ;
    rdfs:label "millimetre"@en ;
    rdfs:comment "SI unit of length: 1/1000 of a metre"@en .

om:metre a om:LengthUnit ;
    rdfs:label "metre"@en ;
    rdfs:comment "SI base unit of length"@en .

om:centimetre a om:LengthUnit ;
    rdfs:label "centimetre"@en ;
    rdfs:comment "1/100 of a metre"@en .

om:inch a om:LengthUnit ;
    rdfs:label "inch"@en ;
    rdfs:comment "Imperial unit of length: 25.4 mm"@en .

om:micrometre a om:LengthUnit ;
    rdfs:label "micrometre"@en ;
    rdfs:comment "1/1000000 of a metre (micron)"@en .

# ============================================
# Angle Grinder Product Instances
# ============================================

ex:anglegrinder_001 a ag:AngleGrinder ;
    rdfs:label "AG-2000 Professional Angle Grinder"@en ;
    rdfs:comment "High-end professional model with advanced features"@en ;
    ag:hasPart ex:crowngear_001, ex:crowngear_002 .

ex:anglegrinder_002 a ag:AngleGrinder ;
    rdfs:label "AG-1500 Standard Angle Grinder"@en ;
    rdfs:comment "Standard consumer model"@en ;
    ag:hasPart ex:crowngear_003 .

# ============================================
# Measurable Characteristics
# ============================================

ex:toothlength_char_001 a cfm:MeasurableCharacteristics ;
    rdfs:label "Tooth Length Characteristic (Gear #001)"@en ;
    rdfs:comment "Geometric characteristic being measured"@en .

ex:toothlength_char_002 a cfm:MeasurableCharacteristics ;
    rdfs:label "Tooth Length Characteristic (Gear #002)"@en ;
    rdfs:comment "Geometric characteristic being measured"@en .

ex:toothlength_char_003 a cfm:MeasurableCharacteristics ;
    rdfs:label "Tooth Length Characteristic (Gear #003)"@en ;
    rdfs:comment "Geometric characteristic being measured"@en .

# ============================================
# Crown Gear Part Instances
# ============================================

ex:crowngear_001 a ag:CrownGear ;
    rdfs:label "Crown Gear #001"@en ;
    rdfs:comment "Manually inspected, high quality part"@en ;
    cfm:hasScan ex:pointcloud_001 ;
    cfm:hasCharacteristic ex:toothlength_char_001 .  

ex:crowngear_002 a ag:CrownGear ;
    rdfs:label "Crown Gear #002"@en ;
    rdfs:comment "Automated vision inspection"@en ;
    cfm:hasScan ex:pointcloud_002 ;
    cfm:hasCharacteristic ex:toothlength_char_002 .  

ex:crowngear_003 a ag:CrownGear ;
    rdfs:label "Crown Gear #003"@en ;
    rdfs:comment "Partially occluded during scan"@en ;
    cfm:hasScan ex:pointcloud_003 ;
    cfm:hasCharacteristic ex:toothlength_char_003 .  

# ============================================
# Point Cloud Scan Data
# ============================================

ex:pointcloud_001 a cfm:PointCloud ;
    rdfs:label "Point Cloud Scan #001"@en ;
    rdfs:comment "High-resolution scan from premium scanner"@en .

ex:pointcloud_002 a cfm:PointCloud ;
    rdfs:label "Point Cloud Scan #002"@en ;
    rdfs:comment "Standard resolution scan"@en .

ex:pointcloud_003 a cfm:PointCloud ;
    rdfs:label "Point Cloud Scan #003"@en ;
    rdfs:comment "Partial scan with occlusions"@en .

