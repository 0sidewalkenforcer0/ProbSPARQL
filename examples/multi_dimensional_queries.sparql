# Multi-Dimensional GMM SPARQL Queries

# This file contains example SPARQL queries demonstrating the usage of
# multi-dimensional GMMs with ProbSPARQL functions.

PREFIX prob: <http://probsparql.org/function#>
PREFIX uq: <http://www.example.org/uncertainQuantities#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

# ============================================================================
# 1. Multi-Dimensional PDF Evaluation
# ============================================================================

# Query 1a: Evaluate PDF at a 2D point
SELECT ?pdf WHERE {
  <var1> uq:hasDistribution ?gmm .
  BIND(prob:pdf(?gmm, "[2.5, 2.5]") AS ?pdf)
}

# Query 1b: Evaluate PDF at a 3D point (RGB color)
SELECT ?pdf WHERE {
  <color1> uq:hasDistribution ?gmm .
  BIND(prob:pdf(?gmm, "[128.0, 128.0, 128.0]") AS ?pdf)
}

# Query 1c: Evaluate PDF at a 4D point (space-time)
SELECT ?pdf WHERE {
  <event1> uq:hasDistribution ?gmm .
  BIND(prob:pdf(?gmm, "[10.0, 20.0, 30.0, 1000.0]") AS ?pdf)
}

# Query 1d: Evaluate Log-PDF at a 2D point (numerically stable)
SELECT ?logpdf WHERE {
  <var1> uq:hasDistribution ?gmm .
  BIND(prob:logpdf(?gmm, "[2.5, 2.5]") AS ?logpdf)
}

# Query 1e: Evaluate Log-PDF at a 3D point (RGB color)
SELECT ?logpdf WHERE {
  <color1> uq:hasDistribution ?gmm .
  BIND(prob:logpdf(?gmm, "[128.0, 128.0, 128.0]") AS ?logpdf)
}

# Query 1f: Evaluate CDF at a 2D point (cumulative probability)
SELECT ?cdf WHERE {
  <var1> uq:hasDistribution ?gmm .
  BIND(prob:cdf(?gmm, "[2.5, 2.5]") AS ?cdf)
}

# Query 1g: Evaluate Log-CDF at a 2D point (numerically stable)
SELECT ?logcdf WHERE {
  <var1> uq:hasDistribution ?gmm .
  BIND(prob:logcdf(?gmm, "[2.5, 2.5]") AS ?logcdf)
}

# ============================================================================
# 2. Multi-Dimensional KL Divergence
# ============================================================================

# Query 2a: Compute KL divergence between two 2D GMMs
SELECT ?kl WHERE {
  <var1> uq:hasDistribution ?gmm1 .
  <var2> uq:hasDistribution ?gmm2 .
  BIND(prob:kldivergence(?gmm1, ?gmm2) AS ?kl)
}

# Query 2b: Symmetric KL divergence (average of both directions)
SELECT ?symmetric_kl WHERE {
  <var1> uq:hasDistribution ?gmm1 .
  <var2> uq:hasDistribution ?gmm2 .
  BIND(prob:kldivergence(?gmm1, ?gmm2) AS ?kl1)
  BIND(prob:kldivergence(?gmm2, ?gmm1) AS ?kl2)
  BIND((?kl1 + ?kl2) / 2 AS ?symmetric_kl)
}

# ============================================================================
# 3. Multi-Dimensional Jensen-Shannon Divergence
# ============================================================================

# Query 3a: Compute JS divergence between two 2D GMMs
SELECT ?js WHERE {
  <var1> uq:hasDistribution ?gmm1 .
  <var2> uq:hasDistribution ?gmm2 .
  BIND(prob:jsdivergence(?gmm1, ?gmm2) AS ?js)
}

# Query 3b: Jensen-Shannon distance (square root of JS divergence)
SELECT ?js_distance WHERE {
  <var1> uq:hasDistribution ?gmm1 .
  <var2> uq:hasDistribution ?gmm2 .
  BIND(prob:jsdivergence(?gmm1, ?gmm2) AS ?js)
  BIND(xsd:double(SQRT(?js)) AS ?js_distance)
}

# ============================================================================
# 4. Multi-Dimensional Manipulation Functions
# ============================================================================

# Query 4a: Compute mean of 2D GMM
SELECT ?mean WHERE {
  <var1> uq:hasDistribution ?gmm .
  BIND(prob:mean(?gmm) AS ?mean)
}

# Query 4b: Compute standard deviation of 3D GMM
SELECT ?std WHERE {
  <color1> uq:hasDistribution ?gmm .
  BIND(prob:std(?gmm) AS ?std)
}

# Query 4c: Extract mode count of 2D GMM
SELECT ?modes WHERE {
  <var1> uq:hasDistribution ?gmm .
  BIND(prob:modecount(?gmm) AS ?modes)
}

# ============================================================================
# 5. Multi-Dimensional Transformation Functions
# ============================================================================

# Query 5a: Scale 2D GMM by factor 2.0
SELECT ?scaled WHERE {
  <var1> uq:hasDistribution ?gmm .
  BIND(prob:scale(?gmm, 2.0) AS ?scaled)
}

# Query 5b: Shift 2D GMM by vector [1.0, 1.0]
SELECT ?shifted WHERE {
  <var1> uq:hasDistribution ?gmm .
  BIND(prob:shift(?gmm, "[1.0, 1.0]") AS ?shifted)
}

# Query 5c: Joint distribution of two 2D GMMs (results in 4D GMM)
SELECT ?joint WHERE {
  <var1> uq:hasDistribution ?gmm1 .
  <var2> uq:hasDistribution ?gmm2 .
  BIND(prob:joint(?gmm1, ?gmm2) AS ?joint)
}

# Query 5d: Marginal distribution of 4D GMM (select dimensions 0,1)
SELECT ?marginal WHERE {
  <event1> uq:hasDistribution ?gmm .
  BIND(prob:marginal(?gmm, "[0, 1]") AS ?marginal)
}

# ============================================================================
# 6. Combined Analysis: Multi-Dimensional Similarity
# ============================================================================

# Query 6: Compare all 2D GMMs using JS divergence
SELECT ?var1 ?var2 ?similarity WHERE {
  ?var1 uq:hasDistribution ?gmm1 .
  ?var2 uq:hasDistribution ?gmm2 .
  FILTER(?var1 != ?var2)
  
  # Only consider 2D GMMs
  BIND(prob:map(?gmm1, "d") AS ?d1)
  BIND(prob:map(?gmm2, "d") AS ?d2)
  FILTER(?d1 = 2 && ?d2 = 2)
  
  # Compute JS divergence
  BIND(prob:jsdivergence(?gmm1, ?gmm2) AS ?js)
  
  # Convert to similarity (smaller divergence = higher similarity)
  BIND(1.0 / (1.0 + ?js) AS ?similarity)
}
ORDER BY DESC(?similarity)

# ============================================================================
# 7. Statistical Analysis: Multi-Dimensional Moments
# ============================================================================

# Query 7: Extract statistical properties of all multi-D GMMs
SELECT ?var ?d ?k ?mean ?std ?modes WHERE {
  ?var uq:hasDistribution ?gmm .
  
  BIND(prob:map(?gmm, "d") AS ?d)
  BIND(prob:map(?gmm, "K") AS ?k)
  BIND(prob:mean(?gmm) AS ?mean)
  BIND(prob:std(?gmm) AS ?std)
  BIND(prob:modecount(?gmm) AS ?modes)
  
  FILTER(?d > 1)  # Only multi-dimensional GMMs
}
ORDER BY ?d ?var

# ============================================================================
# 8. Advanced: Probability Mass in Regions
# ============================================================================

# Query 8a: Check if a 2D point is likely (PDF > threshold)
SELECT ?point ?pdf ?is_likely WHERE {
  <var1> uq:hasDistribution ?gmm .
  
  VALUES ?point { "[0.0, 0.0]" "[2.5, 2.5]" "[5.0, 5.0]" "[10.0, 10.0]" }
  
  BIND(prob:pdf(?gmm, ?point) AS ?pdf)
  BIND(?pdf > 0.01 AS ?is_likely)
}
ORDER BY DESC(?pdf)

# Query 8b: Compare PDF values at multiple 3D color points
SELECT ?color ?pdf WHERE {
  <color1> uq:hasDistribution ?gmm .
  
  # Pure colors
  VALUES ?color { 
    "[255.0, 0.0, 0.0]"     # Pure red
    "[0.0, 255.0, 0.0]"     # Pure green
    "[0.0, 0.0, 255.0]"     # Pure blue
    "[128.0, 128.0, 128.0]" # Gray
    "[255.0, 255.0, 255.0]" # White
  }
  
  BIND(prob:pdf(?gmm, ?color) AS ?pdf)
}
ORDER BY DESC(?pdf)

# ============================================================================
# 9. Transformation Pipeline: Multi-Dimensional
# ============================================================================

# Query 9: Apply a series of transformations to 2D GMM
SELECT ?original ?scaled ?shifted ?mean_shifted WHERE {
  <var1> uq:hasDistribution ?original .
  
  # Step 1: Scale by 0.5
  BIND(prob:scale(?original, 0.5) AS ?scaled)
  
  # Step 2: Shift scaled GMM by [1.0, 1.0]
  BIND(prob:shift(?scaled, "[1.0, 1.0]") AS ?shifted)
  
  # Step 3: Compute mean of final GMM
  BIND(prob:mean(?shifted) AS ?mean_shifted)
}

# ============================================================================
# 10. Quality Control: Dimension Validation
# ============================================================================

# Query 10: Validate all GMMs and identify dimension mismatches
SELECT ?var ?d ?k ?covariance_type WHERE {
  ?var uq:hasDistribution ?gmm .
  
  BIND(prob:map(?gmm, "d") AS ?d)
  BIND(prob:map(?gmm, "K") AS ?k)
  BIND(prob:map(?gmm, "covariance_type") AS ?covariance_type)
  
  # Flag unusual configurations
  FILTER(?d > 1 && ?k > 1)  # Multi-D with multiple modes
}
ORDER BY ?d ?k
