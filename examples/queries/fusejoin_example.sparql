# Example SPARQL Query with FUSEJOIN Algebra Operator

PREFIX prob: <http://probsparql.org/function#>
PREFIX uq: <http://uncertainty.org/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

# Example: Bayesian fusion of prior and measurement distributions
# Uses FUSEJOIN as a true SPARQL algebra operator (not property function)

SELECT ?sensor ?prior ?measurement ?posterior ?meanPosterior
WHERE {
    # Retrieve sensor with prior belief
    ?sensor uq:hasPriorDistribution ?prior .
    
    # Retrieve measurement distribution
    ?sensor uq:hasMeasurement ?measurement .
    
    # FUSEJOIN: True algebra operator for Bayesian fusion
    # Syntax: FUSEJOIN(?leftVar, ?rightVar, tolerance, ?resultVar) { pattern }
    # - leftVar: left GMM variable (?prior)
    # - rightVar: right GMM variable (?measurement)
    # - tolerance: JS divergence threshold (0.1 = accept if JS ≤ 0.1)
    # - resultVar: output variable for fused GMM (?posterior)
    # - pattern: additional constraints on fused results
    
    FUSEJOIN(?prior, ?measurement, 0.1, ?posterior) {
        # Optional: additional constraints on posterior
        # Empty pattern means no additional constraints
    }
    
    # Compute mean of posterior for reporting
    BIND(prob:mean(?posterior) AS ?meanPosterior)
}
ORDER BY ?sensor

##############################################################################
# Expected Behavior:
##############################################################################
#
# 1. Parse Phase (JavaCC):
#    - FUSEJOIN token recognized
#    - FuseJoinGraphPattern() rule creates ElementFuseJoin
#
# 2. Algebra Generation Phase:
#    - AlgebraGeneratorProbabilistic.visit(ElementFuseJoin)
#    - Creates OpFuseJoin in algebra tree
#
# 3. Execution Phase:
#    - OpExecutorProbabilistic.execute(OpFuseJoin)
#    - Creates QueryIterFuseJoin
#    - Nested-loop iteration:
#      * For each (?sensor, ?prior) binding
#      * For each (?sensor, ?measurement) binding
#      * Compute JS(?prior, ?measurement)
#      * If JS ≤ 0.1:
#        - Fuse GMMs using Bayesian product
#        - Bind ?posterior to fused GMM
#        - Yield merged binding
#
# 4. Result:
#    - Only compatible distributions (JS ≤ 0.1) are fused
#    - Posterior = Bayesian product of prior and measurement
#    - Mean of posterior computed for readability
#
##############################################################################
# Comparison with Property Function Approach:
##############################################################################
#
# Property Function (existing FuzzyJoinPF):
#   ?prior prob:fuzzyJoin (?measurement, 0.1, ?posterior) .
#
# Algebra Operator (new FUSEJOIN):
#   FUSEJOIN(?prior, ?measurement, 0.1, ?posterior) { }
#
# Differences:
# 1. Property Function:
#    - Extension point in Jena (magicProperties)
#    - Not part of SPARQL standard
#    - Cannot publish as "SPARQL extension"
#    - Predicate-like syntax
#
# 2. Algebra Operator:
#    - True extension of SPARQL 1.1 grammar
#    - Modifies JavaCC parser
#    - Can publish as academic contribution to SPARQL standard
#    - Pattern-like syntax (similar to OPTIONAL, FILTER)
#    - More aligned with SPARQL language design
#
##############################################################################
# Academic Contribution:
##############################################################################
#
# This implementation enables publication of:
#
# "Extending SPARQL 1.1 with Probabilistic Fusion Joins: 
#  A Grammar-level Integration for Bayesian Inference in Knowledge Graphs"
#
# Key contributions:
# 1. JavaCC grammar extension for FUSEJOIN keyword
# 2. New syntax element (ElementFuseJoin) in parse tree
# 3. New algebra operator (OpFuseJoin) in algebra tree
# 4. Custom iterator (QueryIterFuseJoin) with JS divergence filtering
# 5. Bayesian fusion using Gaussian product formula
# 6. Backward-compatible with SPARQL 1.1 standard
#
# This follows the pattern established by:
# - Ferrada et al. (similarity joins in SPARQL)
# - SPARQL 1.1 standard operators (OPTIONAL, FILTER, etc.)
#
##############################################################################
