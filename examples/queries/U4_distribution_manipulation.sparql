# U4: Distribution Manipulation
# "For spindles, fuse caliper and laser measurements, then extract MAP diameter for robot control."
#
# The data has one caliper distribution and one laser distribution per spindle diameter.
# This query first pairs measurements by the shared diameter characteristic, then applies
# the ProbSPARQL functions directly:
# - prob:jsdivergence checks whether the two distributions are close enough.
# - prob:fuse creates the fused posterior distribution.
# - prob:map, prob:mean, and prob:std extract actionable summaries.

PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX ag: <http://example.org/ontology/anglegrinder#>
PREFIX cfm: <http://example.org/ontology/cfm#>
PREFIX om: <http://example.org/ontology/om#>
PREFIX uq: <http://example.org/ontology/uncertainty#>
PREFIX prob: <http://probsparql.org/function#>

SELECT ?spindle ?spindleLabel ?caliperValue ?laserValue ?jsDivergence
       ?fusedDist ?mapDiameter ?meanDiameter ?stdDev
WHERE {
  ?spindle a ag:Spindle ;
           rdfs:label ?spindleLabel ;
           ag:hasDiameterCharacteristic ?diameterChar .

  ?caliperMeasure cfm:measuresCharacteristic ?diameterChar ;
                  rdfs:label ?caliperLabel ;
                  cfm:hasProbabilisticValue ?rvCaliper ;
                  om:hasValue ?caliperValue .
  FILTER(CONTAINS(?caliperLabel, "Caliper"))
  ?rvCaliper uq:hasDistribution ?caliperDist .

  ?laserMeasure cfm:measuresCharacteristic ?diameterChar ;
                rdfs:label ?laserLabel ;
                cfm:hasProbabilisticValue ?rvLaser ;
                om:hasValue ?laserValue .
  FILTER(CONTAINS(?laserLabel, "Laser"))
  ?rvLaser uq:hasDistribution ?laserDist .

  BIND(prob:jsdivergence(?caliperDist, ?laserDist) AS ?jsDivergence)
  FILTER(?jsDivergence <= 0.3)

  BIND(prob:fuse(?caliperDist, ?laserDist) AS ?fusedDist)
  BIND(prob:map(?fusedDist) AS ?mapDiameter)
  BIND(prob:mean(?fusedDist) AS ?meanDiameter)
  BIND(prob:std(?fusedDist) AS ?stdDev)
}
ORDER BY ?spindleLabel
