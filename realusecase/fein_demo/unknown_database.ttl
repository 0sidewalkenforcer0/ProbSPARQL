ex:unknownGear_002 a ag:CrownGear ;
    rdfs:label "Crown gear of unknown grinder 002 (DEMO)"@en ;
    ag:hasToothLengthCharacteristic ex:unknown_toothlen_char_002 ;
    ag:hasHardnessCharacteristic    ex:unknown_hardness_char_002 .

ex:unknown_toothlen_char_002 a cfm:MeasurableCharacteristics ;
    rdfs:label "Tooth-length characteristic — unknown gear 002"@en .

ex:unknown_meas_toothlen_002 a om:Measure ;
