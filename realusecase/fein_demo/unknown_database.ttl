    om:hasUnit  om:millimetre ;
    om:hasValue "7.34"^^xsd:double ;
    cfm:measuresCharacteristic  ex:unknown_toothlen_char_002 ;
    uq:representedBy   ex:unknown_rv_toothlen_002 .

ex:unknown_rv_toothlen_002 a uq:RandomVariable ;
    rdfs:label "Tooth-length distribution — unknown gear 002 (DEMO)"@en ;
    uq:hasDomain  uq:nonNegativeDouble ;
    uq:hasDistribution
        "{\"n_components\":1,\"dimensions\":1,\"covariance_type\":\"diag\",\"weights\":[1.0],\"means\":[[7.34]],\"covariances\":[[0.01]]}"^^uq:gmmLiteral .

ex:unknown_hardness_char_002 a cfm:MeasurableCharacteristics ;
    rdfs:label "Hardness characteristic — unknown gear 002"@en .

ex:unknown_meas_hardness_002 a om:Measure ;
    rdfs:label "Rockwell-C hardness measurement — unknown gear 002 (DEMO)"@en ;
    om:hasUnit  om:hardnessRockwellC ;
    om:hasValue "64.1"^^xsd:double ;
    cfm:measuresCharacteristic  ex:unknown_hardness_char_002 ;
    uq:representedBy   ex:unknown_rv_hardness_002 .

ex:unknown_rv_hardness_002 a uq:RandomVariable ;
    rdfs:label "Hardness distribution — unknown gear 002 (DEMO)"@en ;
    uq:hasDomain  uq:nonNegativeDouble ;
    uq:hasDistribution
        "{\"n_components\":1,\"dimensions\":1,\"covariance_type\":\"diag\",\"weights\":[1.0],\"means\":[[64.1]],\"covariances\":[[0.25]]}"^^uq:gmmLiteral .

