# =============================================================================
#  FEIN CG 15-125 Variant Identification — HISTORICAL DATABASE
#  Three variants: BL (standard), BL Inox (stainless-steel optimised), BLP (lightweight)
#
#  NOTE: ALL MEASUREMENT VALUES AND DISTRIBUTION PARAMETERS ARE TOY/DEMO VALUES.
#        They do NOT represent real FEIN product data.
#
#  Modeling pattern follows benchmark/data/benchmark_S1.ttl:
#    gear → ag:hasPart ← grinder
#    gear → ag:hasToothLengthCharacteristic → cfm:MeasurableCharacteristics
#    measurement → cfm:measuresCharacteristic → characteristic
#    measurement → uq:representedBy  → uq:RandomVariable
#    uq:RandomVariable → uq:hasDistribution   → uq:gmmLiteral
#
#  New properties introduced (no equivalent exists in schema):
#    ag:hasToothLengthCharacteristic  — mirrors im:hasHardCharacteristic pattern
#    ag:hasHardnessCharacteristic     — mirrors im:hasHardCharacteristic pattern
#    ag:hasTypeToothLengthDistribution — links type class to aggregate RV
#    ag:hasTypeHardnessDistribution    — links type class to aggregate RV
#    uq:aggregatedInto                 — instance RV → type-level aggregate RV (provenance)
# =============================================================================

@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ag:   <http://example.org/ontology/anglegrinder#> .
@prefix cfm:  <http://example.org/ontology/cfm#> .
@prefix om:   <http://example.org/ontology/om#> .
@prefix uq:   <http://example.org/ontology/uncertainty#> .
@prefix ex:   <http://example.org/data/fein-demo/> .

# ─────────────────────────────────────────────────────────────────────────────
#  Units
# ─────────────────────────────────────────────────────────────────────────────

om:millimetre a om:LengthUnit ;
    rdfs:label "millimetre"@en .

om:hardnessRockwellC a om:Unit ;
    rdfs:label "Rockwell C hardness unit (HRC)"@en .

# ─────────────────────────────────────────────────────────────────────────────
#  New extension properties  (closest equivalents noted in comments)
# ─────────────────────────────────────────────────────────────────────────────

ag:hasToothLengthCharacteristic a owl:ObjectProperty ;
    rdfs:label "has tooth-length characteristic"@en ;
    rdfs:comment "Links a CrownGear to its tooth-length MeasurableCharacteristics node. Follows the same pattern as im:hasHardCharacteristic in the inspection-measurement module."@en ;
    rdfs:domain ag:CrownGear ;
    rdfs:range  cfm:MeasurableCharacteristics .

ag:hasHardnessCharacteristic a owl:ObjectProperty ;
    rdfs:label "has hardness characteristic"@en ;
    rdfs:comment "Links a CrownGear to its hardness MeasurableCharacteristics node. Mirrors im:hasHardCharacteristic."@en ;
    rdfs:domain ag:CrownGear ;
    rdfs:range  cfm:MeasurableCharacteristics .

ag:hasTypeToothLengthDistribution a owl:ObjectProperty ;
    rdfs:label "has type-level tooth-length distribution"@en ;
    rdfs:comment "Links a FEIN variant type resource to the uq:RandomVariable that encodes the aggregate (type-level) tooth-length distribution, i.e. p(toothLength | type). No equivalent exists in core schema."@en ;
    rdfs:domain owl:Class ;
    rdfs:range  uq:RandomVariable .

ag:hasTypeHardnessDistribution a owl:ObjectProperty ;
    rdfs:label "has type-level hardness distribution"@en ;
    rdfs:comment "Links a FEIN variant type resource to the uq:RandomVariable that encodes the aggregate hardness distribution p(hardness | type)."@en ;
    rdfs:domain owl:Class ;
    rdfs:range  uq:RandomVariable .

uq:aggregatedInto a owl:ObjectProperty ;
    rdfs:label "aggregated into"@en ;
    rdfs:comment "Provenance link from an individual-measurement uq:RandomVariable to the type-level aggregate uq:RandomVariable that subsumes it. Closest available: prov:wasDerivedFrom; replaced here by a local extension."@en ;
    rdfs:domain uq:RandomVariable ;
    rdfs:range  uq:RandomVariable .

ag:hasTypeClassPrototype a owl:ObjectProperty ;
    rdfs:label "has type classification prototype"@en ;
    rdfs:comment "Links a FEIN variant type to a 1-component 3D GMM whose mean encodes its one-hot position in classification space: BL=[1,0,0], P=[0,1,0], BLP=[0,0,1]. JSD between the unknown grinder's classGMM and this prototype gives the classification evidence score for that variant."@en ;
    rdfs:domain owl:Class ;
    rdfs:range  uq:RandomVariable .

# ─────────────────────────────────────────────────────────────────────────────
#  Three FEIN Angle Grinder Model Series  (each rdfs:subClassOf ag:AngleGrinder)
#  ag:FeinCG15125BL        rdfs:subClassOf ag:AngleGrinder
#  ag:FeinCG15125P   rdfs:subClassOf ag:AngleGrinder
#  ag:FeinCG15125BLP       rdfs:subClassOf ag:AngleGrinder
# ─────────────────────────────────────────────────────────────────────────────

ag:FeinCG15125BL a owl:Class ;
    rdfs:subClassOf ag:AngleGrinder ;
    rdfs:label "FEIN CG 15-125 BL"@en ;
    rdfs:comment "FEIN CG 15-125 BL angle grinder model series. Demo class only." .

ag:FeinCG15125P a owl:Class ;
    rdfs:subClassOf ag:AngleGrinder ;
    rdfs:label "FEIN CG 15-125 P"@en ;
    rdfs:comment "FEIN CG 15-125 P angle grinder model series. Demo class only." .

ag:FeinCG15125BLP a owl:Class ;
    rdfs:subClassOf ag:AngleGrinder ;
    rdfs:label "FEIN CG 15-125 BLP"@en ;
    rdfs:comment "FEIN CG 15-125 BLP angle grinder model series. Demo class only." .

# ─────────────────────────────────────────────────────────────────────────────
#  One-hot Classification Prototypes
#  Each variant maps to a 1-component 3D GMM at its one-hot position.
#  Tiny covariances (1e-4) make each component near-degenerate (≈ point mass).
#  Order of dimensions: [BL, P, BLP]
# ─────────────────────────────────────────────────────────────────────────────

ag:FeinCG15125BL  ag:hasTypeClassPrototype ex:proto_class_BL .
ag:FeinCG15125P   ag:hasTypeClassPrototype ex:proto_class_P .
ag:FeinCG15125BLP ag:hasTypeClassPrototype ex:proto_class_BLP .

ex:proto_class_BL a uq:RandomVariable ;
    rdfs:label "Classification prototype — BL (one-hot [1,0,0])"@en ;
    rdfs:comment "Near-degenerate GMM at [1,0,0] in 3D classification space. JSD against classGMM gives classification evidence for the BL variant."@en ;
    uq:hasDistribution
        "{\"n_components\":1,\"dimensions\":3,\"covariance_type\":\"diag\",\"weights\":[1.0],\"means\":[[1.0,0.0,0.0]],\"covariances\":[[1e-4,1e-4,1e-4]]}"^^uq:gmmLiteral .

ex:proto_class_P a uq:RandomVariable ;
    rdfs:label "Classification prototype — P (one-hot [0,1,0])"@en ;
    rdfs:comment "Near-degenerate GMM at [0,1,0] in 3D classification space. JSD against classGMM gives classification evidence for the P variant."@en ;
    uq:hasDistribution
        "{\"n_components\":1,\"dimensions\":3,\"covariance_type\":\"diag\",\"weights\":[1.0],\"means\":[[0.0,1.0,0.0]],\"covariances\":[[1e-4,1e-4,1e-4]]}"^^uq:gmmLiteral .

ex:proto_class_BLP a uq:RandomVariable ;
    rdfs:label "Classification prototype — BLP (one-hot [0,0,1])"@en ;
    rdfs:comment "Near-degenerate GMM at [0,0,1] in 3D classification space. JSD against classGMM gives classification evidence for the BLP variant."@en ;
    uq:hasDistribution
        "{\"n_components\":1,\"dimensions\":3,\"covariance_type\":\"diag\",\"weights\":[1.0],\"means\":[[0.0,0.0,1.0]],\"covariances\":[[1e-4,1e-4,1e-4]]}"^^uq:gmmLiteral .

# ─────────────────────────────────────────────────────────────────────────────
#  Type-Level Statistical Profiles (aggregate distributions)
#  Values are TOY/DEMO — not real measurements.
#  BL:    tooth ~7.00 mm, hardness ~61.5 HRC
#  INOX:  tooth ~7.35 mm, hardness ~64.0 HRC
#  BLP:   tooth ~6.65 mm, hardness ~60.0 HRC
# ─────────────────────────────────────────────────────────────────────────────

# --- BL type-level distributions ---

ag:FeinCG15125BL ag:hasTypeToothLengthDistribution ex:globalRV_toothlen_BL .
ag:FeinCG15125BL ag:hasTypeHardnessDistribution    ex:globalRV_hardness_BL .

ex:globalRV_toothlen_BL a uq:RandomVariable ;
    rdfs:label "Type-level tooth-length distribution — FEIN CG 15-125 BL (DEMO)"@en ;
    rdfs:comment "Aggregate Gaussian over historical BL tooth-length measurements. TOY VALUE."@en ;
    uq:hasDomain  uq:nonNegativeDouble ;
    uq:hasDistribution
        "{\"n_components\":1,\"dimensions\":1,\"covariance_type\":\"diag\",\"weights\":[1.0],\"means\":[[7.00]],\"covariances\":[[0.04]]}"^^uq:gmmLiteral .

ex:globalRV_hardness_BL a uq:RandomVariable ;
    rdfs:label "Type-level hardness distribution — FEIN CG 15-125 BL (DEMO)"@en ;
    rdfs:comment "Aggregate Gaussian over historical BL hardness measurements. TOY VALUE."@en ;
    uq:hasDomain  uq:nonNegativeDouble ;
    uq:hasDistribution
        "{\"n_components\":1,\"dimensions\":1,\"covariance_type\":\"diag\",\"weights\":[1.0],\"means\":[[61.5]],\"covariances\":[[0.25]]}"^^uq:gmmLiteral .

# --- BL Inox type-level distributions ---

ag:FeinCG15125P ag:hasTypeToothLengthDistribution ex:globalRV_toothlen_INOX .
ag:FeinCG15125P ag:hasTypeHardnessDistribution    ex:globalRV_hardness_INOX .

ex:globalRV_toothlen_INOX a uq:RandomVariable ;
    rdfs:label "Type-level tooth-length distribution — FEIN CG 15-125 BL Inox (DEMO)"@en ;
    rdfs:comment "Aggregate Gaussian over historical BL Inox tooth-length measurements. TOY VALUE."@en ;
    uq:hasDomain  uq:nonNegativeDouble ;
    uq:hasDistribution
        "{\"n_components\":1,\"dimensions\":1,\"covariance_type\":\"diag\",\"weights\":[1.0],\"means\":[[7.35]],\"covariances\":[[0.04]]}"^^uq:gmmLiteral .

ex:globalRV_hardness_INOX a uq:RandomVariable ;
    rdfs:label "Type-level hardness distribution — FEIN CG 15-125 BL Inox (DEMO)"@en ;
    rdfs:comment "Aggregate Gaussian over historical BL Inox hardness measurements. TOY VALUE."@en ;
    uq:hasDomain  uq:nonNegativeDouble ;
    uq:hasDistribution
        "{\"n_components\":1,\"dimensions\":1,\"covariance_type\":\"diag\",\"weights\":[1.0],\"means\":[[64.0]],\"covariances\":[[0.25]]}"^^uq:gmmLiteral .

# --- BLP type-level distributions ---

ag:FeinCG15125BLP ag:hasTypeToothLengthDistribution ex:globalRV_toothlen_BLP .
ag:FeinCG15125BLP ag:hasTypeHardnessDistribution    ex:globalRV_hardness_BLP .

ex:globalRV_toothlen_BLP a uq:RandomVariable ;
    rdfs:label "Type-level tooth-length distribution — FEIN CG 15-125 BLP (DEMO)"@en ;
    rdfs:comment "Aggregate Gaussian over historical BLP tooth-length measurements. TOY VALUE."@en ;
    uq:hasDomain  uq:nonNegativeDouble ;
    uq:hasDistribution
        "{\"n_components\":1,\"dimensions\":1,\"covariance_type\":\"diag\",\"weights\":[1.0],\"means\":[[6.65]],\"covariances\":[[0.04]]}"^^uq:gmmLiteral .

ex:globalRV_hardness_BLP a uq:RandomVariable ;
    rdfs:label "Type-level hardness distribution — FEIN CG 15-125 BLP (DEMO)"@en ;
    rdfs:comment "Aggregate Gaussian over historical BLP hardness measurements. TOY VALUE."@en ;
    uq:hasDomain  uq:nonNegativeDouble ;
    uq:hasDistribution
        "{\"n_components\":1,\"dimensions\":1,\"covariance_type\":\"diag\",\"weights\":[1.0],\"means\":[[60.0]],\"covariances\":[[0.25]]}"^^uq:gmmLiteral .

# =============================================================================
#  Historical Instance: FEIN CG 15-125 BL — unit #001
#  TOY VALUES: tooth ~7.03 mm, hardness ~61.4 HRC
# =============================================================================

ex:hist_grinder_BL_001 a ag:FeinCG15125BL ;
    rdfs:label "Historical FEIN CG 15-125 BL — unit 001 (DEMO)"@en ;
    ag:hasPart ex:hist_gear_BL_001 .

ex:hist_gear_BL_001 a ag:CrownGear ;
    rdfs:label "Crown gear — hist BL 001 (DEMO)"@en ;
    ag:hasToothLengthCharacteristic ex:hist_toothlen_char_BL_001 ;
    ag:hasHardnessCharacteristic    ex:hist_hardness_char_BL_001 .

# Tooth-length characteristic node
ex:hist_toothlen_char_BL_001 a cfm:MeasurableCharacteristics ;
    rdfs:label "Tooth-length characteristic — hist BL 001"@en .

# Tooth-length measurement
ex:hist_meas_toothlen_BL_001 a om:Measure ;
    rdfs:label "CT tooth-length measurement — hist BL 001 (DEMO)"@en ;
    om:hasUnit  om:millimetre ;
    om:hasValue "7.03"^^xsd:double ;
    cfm:measuresCharacteristic  ex:hist_toothlen_char_BL_001 ;
    uq:representedBy   ex:hist_rv_toothlen_BL_001 .

ex:hist_rv_toothlen_BL_001 a uq:RandomVariable ;
    rdfs:label "Tooth-length distribution — hist BL 001 (DEMO)"@en ;
    rdfs:comment "TOY VALUE."@en ;
    uq:hasDomain  uq:nonNegativeDouble ;
    uq:hasDistribution
        "{\"n_components\":1,\"dimensions\":1,\"covariance_type\":\"diag\",\"weights\":[1.0],\"means\":[[7.03]],\"covariances\":[[0.01]]}"^^uq:gmmLiteral ;
    uq:aggregatedInto ex:globalRV_toothlen_BL .

# Hardness characteristic node
ex:hist_hardness_char_BL_001 a cfm:MeasurableCharacteristics ;
    rdfs:label "Hardness characteristic — hist BL 001"@en .

# Hardness measurement
ex:hist_meas_hardness_BL_001 a om:Measure ;
    rdfs:label "Rockwell-C hardness measurement — hist BL 001 (DEMO)"@en ;
    om:hasUnit  om:hardnessRockwellC ;
    om:hasValue "61.4"^^xsd:double ;
    cfm:measuresCharacteristic  ex:hist_hardness_char_BL_001 ;
    uq:representedBy   ex:hist_rv_hardness_BL_001 .

ex:hist_rv_hardness_BL_001 a uq:RandomVariable ;
    rdfs:label "Hardness distribution — hist BL 001 (DEMO)"@en ;
    rdfs:comment "TOY VALUE."@en ;
    uq:hasDomain  uq:nonNegativeDouble ;
    uq:hasDistribution
        "{\"n_components\":1,\"dimensions\":1,\"covariance_type\":\"diag\",\"weights\":[1.0],\"means\":[[61.4]],\"covariances\":[[0.25]]}"^^uq:gmmLiteral ;
    uq:aggregatedInto ex:globalRV_hardness_BL .

