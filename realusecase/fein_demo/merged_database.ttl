    uq:aggregatedInto ex:globalRV_hardness_BL .

# ─────────────────────────────────────────────────────────────────────────────
#  Historical Instance: FEIN CG 15-125 BL Inox — unit #001  (TOY: 7.34 mm / 64.1 HRC)
# ─────────────────────────────────────────────────────────────────────────────

ex:hist_grinder_INOX_001 a ag:FeinCG15125P ;
    rdfs:label "Historical FEIN CG 15-125 BL Inox — unit 001 (DEMO)"@en ;
    ag:hasPart ex:hist_gear_INOX_001 .

ex:hist_gear_INOX_001 a ag:CrownGear ;
    ag:hasToothLengthCharacteristic ex:hist_toothlen_char_INOX_001 ;
    ag:hasHardnessCharacteristic    ex:hist_hardness_char_INOX_001 .

ex:hist_toothlen_char_INOX_001 a cfm:MeasurableCharacteristics .
ex:hist_meas_toothlen_INOX_001 a om:Measure ;
    om:hasUnit om:millimetre ; om:hasValue "7.34"^^xsd:double ;
    cfm:measuresCharacteristic ex:hist_toothlen_char_INOX_001 ;
    uq:representedBy  ex:hist_rv_toothlen_INOX_001 .
ex:hist_rv_toothlen_INOX_001 a uq:RandomVariable ;
    uq:hasDomain uq:nonNegativeDouble ;
    uq:hasDistribution "{\"n_components\":1,\"dimensions\":1,\"covariance_type\":\"diag\",\"weights\":[1.0],\"means\":[[7.34]],\"covariances\":[[0.01]]}"^^uq:gmmLiteral ;
    uq:aggregatedInto ex:globalRV_toothlen_INOX .

