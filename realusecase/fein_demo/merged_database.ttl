    om:hasUnit om:millimetre ; om:hasValue "6.97"^^xsd:double ;
    cfm:measuresCharacteristic ex:hist_toothlen_char_BL_002 ;
    uq:representedBy  ex:hist_rv_toothlen_BL_002 .
ex:hist_rv_toothlen_BL_002 a uq:RandomVariable ;
    uq:hasDomain uq:nonNegativeDouble ;
    uq:hasDistribution "{\"n_components\":1,\"dimensions\":1,\"covariance_type\":\"diag\",\"weights\":[1.0],\"means\":[[6.97]],\"covariances\":[[0.01]]}"^^uq:gmmLiteral ;
    uq:aggregatedInto ex:globalRV_toothlen_BL .

ex:hist_hardness_char_BL_002 a cfm:MeasurableCharacteristics .
