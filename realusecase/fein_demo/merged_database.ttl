    om:hasUnit om:hardnessRockwellC ; om:hasValue "61.6"^^xsd:double ;
    cfm:measuresCharacteristic ex:hist_hardness_char_BL_002 ;
    uq:representedBy  ex:hist_rv_hardness_BL_002 .
ex:hist_rv_hardness_BL_002 a uq:RandomVariable ;
    uq:hasDomain uq:nonNegativeDouble ;
