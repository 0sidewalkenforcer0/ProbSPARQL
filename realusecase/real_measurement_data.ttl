@prefix ex: <https://w3id.org/probsparql/examples/real-manufacturing/> .
@prefix cfc: <https://w3id.org/circular-factory/ontology/product-structure#> .
@prefix ag: <https://w3id.org/circular-factory/ontology/angle-grinder#> .
@prefix im: <https://w3id.org/circular-factory/ontology/inspection-measurement#> .
@prefix om: <http://www.ontology-of-units-of-measure.org/resource/om-2/> .
@prefix uq: <http://example.org/ontology/uncertainty#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# Real manufacturing measurement data for ProbSPARQL validation
# Generated from:
# - Data_Hardness_Temp_RMS_reduced.xlsx
# - Data C02.xlsx
#
# The file follows the same modelling pattern used in the paper:
# sample/component -> measurable characteristic -> measurement
# measurement -> uq:representedBy -> uq:RandomVariable
# random variable -> uq:hasDomain / uq:hasDistribution
#################################################################

ex:DataHardnessTempRMSReduced a ex:RealMeasurementDataset ;
    rdfs:label "Hardness, temperature, RMS, and residual-stress measurement dataset"@en ;
    ex:rowCount "40"^^xsd:integer .

ex:DataC02Roughness a ex:RealMeasurementDataset ;
    rdfs:label "C02 process-parameter and surface-roughness measurement dataset"@en ;
    ex:rowCount "17"^^xsd:integer .

ex:HardnessRmsSample rdfs:subClassOf cfc:Part .
ex:C02SurfaceSample rdfs:subClassOf cfc:Part .
ex:ProcessCondition a rdfs:Class .
ex:RMSMeasurement rdfs:subClassOf im:StructuredLightMeasurement .
ex:ResidualStressMeasurement rdfs:subClassOf im:StructuredLightMeasurement .
ex:HardnessMeasurement rdfs:subClassOf im:StructuredLightMeasurement .
ex:SurfaceRoughnessMeasurement rdfs:subClassOf im:StructuredLightMeasurement .
ex:EmpiricalSurfaceRoughnessMeasurement rdfs:subClassOf im:StructuredLightMeasurement .

ex:hasProcessCondition a rdf:Property .
ex:hasReplicate a rdf:Property .
ex:carbonContent a rdf:Property .
ex:temperature a rdf:Property .
ex:laserPower a rdf:Property .
ex:processingSpeed a rdf:Property .
ex:lineEnergy a rdf:Property .
ex:standardDeviation a rdf:Property .
ex:hasRMSCharacteristic a rdf:Property .
ex:hasResidualStressCharacteristic a rdf:Property .
ex:hasHardnessCharacteristic a rdf:Property .
ex:hasSaCharacteristic a rdf:Property .
ex:hasSqCharacteristic a rdf:Property .
ex:hasRaCharacteristic a rdf:Property .
ex:hasRqCharacteristic a rdf:Property .
ex:hasRzCharacteristic a rdf:Property .
ex:hasRelativeDensityCharacteristic a rdf:Property .
ex:hasEmpiricalCharacteristic a rdf:Property .

ex:rmsDatasetUnit a om:Unit ;
    rdfs:label "dataset unit for RMS values"@en .

ex:residualStressDatasetUnit a om:Unit ;
    rdfs:label "dataset unit for residual-stress values"@en .

ex:hardnessHV a om:Unit ;
    rdfs:label "Vickers hardness unit"@en .

uq:double a rdfs:Datatype ;
    rdfs:label "double-valued real domain"@en .

uq:nonNegativeDouble a rdfs:Datatype ;
    rdfs:label "non-negative double-valued real domain"@en ;
    rdfs:seeAlso <../examples/ontologies/uncertainty-datatypes.xsd> .

ex:hardCond_CC25_T30 a ex:ProcessCondition ;
    ex:carbonContent "25"^^xsd:double ;
    ex:temperature "30"^^xsd:double ;
