    ex:hasRMSCharacteristic ex:hardSample_001_rmsCharacteristic ;
    ex:hasResidualStressCharacteristic ex:hardSample_001_residualStressCharacteristic ;
    ex:hasHardnessCharacteristic ex:hardSample_001_hardnessCharacteristic .

ex:hardSample_001_rmsCharacteristic a im:MeasurableCharacteristic ;
    rdfs:label "RMS measurement characteristic for hardSample_001"@en ;
    im:isMeasuredBy ex:hardSample_001_rmsMeasurement .

ex:hardSample_001_rmsMeasurement a ex:RMSMeasurement ;
    om:hasValue "270.11889"^^xsd:double ;
    ex:standardDeviation "19.99221"^^xsd:double ;
    om:hasUnit ex:rmsDatasetUnit ;
    uq:representedBy ex:hardSample_001_rmsRV .

ex:hardSample_001_rmsRV a uq:RandomVariable ;
    uq:hasDomain uq:nonNegativeDouble ;
    uq:hasDistribution """{"n_components":1,"dimensions":1,"covariance_type":"diag","weights":[1.0],"means":[[270.11889]],"covariances":[[399.688461]]}"""^^uq:gmmLiteral .

